keybinds {
    normal {
        // default is Ctrl + h / conflicts with my custom kitty config to move panes
        // bind "Ctrl m" { SwitchToMode "Move"; }
        // bind "Alt m" { SwitchToMode "Move"; }
    }
    shared_except "move" "locked" {
        // bind "Ctrl m" { SwitchToMode "Move"; }
    }
    // Claude Code popup — press Alt+c to spawn, Alt+f (default) to toggle visibility.
    shared_except "locked" {
        bind "Alt c" {
            Run "claude" {
                floating true
                x "10%"
                y "10%"
                width "80%"
                height "80%"
                close_on_exit true
            }
        }
    }
}

theme "default"

themes {
    // # AUTO-GENERATED by scripts/apply-theme.sh — edit theme/colors.sh instead
    default {
        bg "#0E1018"
        fg "#D8DCE8"
        red "#F38BA8"
        green "#73DACA"
        blue "#7AA2F7"
        yellow "#BB9AF7"
        magenta "#C7A1FF"
        orange "#E0CCFF"
        cyan "#7DCFFF"
        black "#08090E"
        white "#D8DCE8"
    }
}
