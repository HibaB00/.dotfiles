keybinds {
    normal {
        // default is Ctrl + h / conflicts with my custom kitty config to move panes
        // bind "Ctrl m" { SwitchToMode "Move"; }
        // bind "Alt m" { SwitchToMode "Move"; }
    }
    shared_except "move" "locked" {
        // bind "Ctrl m" { SwitchToMode "Move"; }
    }
    // Claude Code popup — press Alt+c to spawn, Alt+f (default) to toggle visibility.
    shared_except "locked" {
        bind "Alt c" {
            Run "claude" {
                floating true
                x "10%"
                y "10%"
                width "80%"
                height "80%"
                close_on_exit true
            }
        }
    }
}

theme "default"

themes {
    default {
        bg "#585b70" // Surface2
        fg "#cdd6f4"
        red "#f38ba8"
        green "#a6e3a1"
        blue "#89b4fa"
        yellow "#f9e2af"
        magenta "#f5c2e7" // Pink
        orange "#fab387" // Peach
        cyan "#89dceb" // Sky
        black "#181825" // Mantle
        white "#cdd6f4"
    }
}
